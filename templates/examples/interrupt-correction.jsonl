{"apiVersion":"agent-sim/v1","kind":"Scenario","metadata":{"id":"interrupt-correction","locale":"en-US","tags":["interrupt","correction","example"]}}
{"kind":"Persona","spec":{"name":"Alex","language":"en-US","brief":"Impatient caller who barges in mid-answer to correct or ask a fee.","goals":["State the signup need","Interrupt a long agent turn with a clear fee question","Close politely"],"style":"polite but impatient","traits":["impatient","interrupts"],"constraints":["Do not invent card numbers"]}}
{"kind":"Context","spec":{"notes":"Portable scaffold — set Dispatch.metadata for your agent. Script needs a long agent turn."}}
{"kind":"Execute","spec":{"max_turns":10,"timeout_s":180,"first_speaker":"user"}}
{"kind":"Dispatch","spec":{"metadata":"{\"yourProjectKey\":\"REPLACE_ME\"}"}}
{"kind":"Script","spec":{"steps":[{"id":"open","trigger":"silence","delay_ms":700,"say":"Hi, I want to sign up for a basic plan.","once":true,"require_agent_spoke_first":false},{"id":"real_interrupt","trigger":"agent_speaking","barge_in":true,"delay_ms":800,"min_agent_active_ms":400,"say":"Wait — how much is the monthly fee?","once":true,"require_agent_spoke_first":true,"class":"correction","silence_after_cue_ms":2000},{"id":"bye","trigger":"silence","delay_ms":2200,"say":"Thanks, that's all for now. Bye.","once":true,"require_agent_spoke_first":true}],"verify":{"require_during_agent_speech":true}}}
{"kind":"Assert","spec":{"tools":[],"transcript":[{"role":"user","contains_any":["fee","monthly"]}],"outcomes":[{"id":"agent_recovered_after_barge","type":"recovery","min_agent_finals_after_barge_in":1}]}}
{"kind":"PassCriteria","spec":{"criteria":["Caller barged in during agent speech with a clear fee question","Agent yielded and addressed the fee","Call reached a polite close"]}}
